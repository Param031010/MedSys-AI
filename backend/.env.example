# MedsysAI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  Never commit .env — it is listed in .gitignore

# ── AI Provider ──────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appname>
# Create a free cluster at: https://cloud.mongodb.com
# Your Cluster Overview: https://cloud.mongodb.com/v2/6a521dfcc30100abf78cae5b#/overview
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/medsysai?retryWrites=true&w=majority

# ── Server (optional overrides) ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
