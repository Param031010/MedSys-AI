# MedsysAI Backend — Environment Variables
# Copy this file to .env and fill in your values (never commit .env)

# ── Server ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
HOST=0.0.0.0
PORT=8000

# ── Auth / Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Database (optional, add when ready) ──────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/medsysai
