# MedsysAI Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  Never commit .env — it is listed in .gitignore

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get your publishable key at: https://dashboard.clerk.com
# → Your application → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the running FastAPI backend.
# Default for local development:
VITE_API_BASE=http://localhost:8000

# ── TomTom Maps ───────────────────────────────────────────────────────────────
# Get a free API key at: https://developer.tomtom.com/user/register
# Used for: interactive map tiles, hospital/clinic POI search, geocoding
VITE_TOMTOM_KEY=

# ── OpenWeather API ───────────────────────────────────────────────────────────
# Get a free API key at: https://openweathermap.org/api
# Used for: Air Quality Index (AQI) data
VITE_OPENWEATHER_KEY=
